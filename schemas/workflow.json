            "string",
            "null"
          ],
          "default": null
        },
        "max_steps": {
          "description": "Maximum number of steps the AI agent can take (optional, defaults to 100)",
          "type": [
            "integer",
            "null"
          ],
          "format": "uint",
          "default": null,
          "minimum": 0
        },
        "model": {
          "description": "AI model to use (optional, defaults to configured model)",
          "type": [
            "string",
            "null"
          ],
          "default": null
