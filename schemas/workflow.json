        "max_threads": {
          "description": "Set maximum number of concurrent threads (optional, defaults to CPU cores)",
          "type": [
            "integer",
            "null"
          ],
          "format": "uint",
          "default": null,
          "minimum": 0
        },
        "semantic_analysis": {
          "description": "Semantic analysis configuration for symbol indexing (definition, references, typeInfo).\nCan be:\n- `\"file\"` - single-file analysis (default if semantic is enabled)\n- `\"workspace\"` - workspace-wide analysis using base_path as root\n- `{\"mode\": \"workspace\", \"root\": \"/path/to/workspace\"}` - workspace-wide with custom root",
          "anyOf": [
            {
              "$ref": "#/$defs/SemanticAnalysisConfig"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        }
      },
      "required": [
        "js_file"
      ]
    },
    "UseShard": {
      "description": "Configuration for the `shard` step action.\nEvaluates file shards and writes results to workflow state.",
      "type": "object",
      "properties": {
        "file_pattern": {
          "description": "Glob pattern for eligible files (used when js-ast-grep is not set)",
          "type": [
            "string",
            "null"
          ],
          "default": null
        },
        "js-ast-grep": {
          "description": "Optional js-ast-grep configuration for codemod-based pre-filtering.\nWhen set, the engine dry-runs the codemod against matched files and\nonly includes files where the transform produces changes.\nThe `include` field also serves as the file pattern for discovery.",
          "anyOf": [
            {
              "$ref": "#/$defs/UseJSAstGrep"
            },
            {
              "type": "null"
            }
          ],
          "default": null
        },
        "method": {
          "description": "Sharding method configuration — either a built-in algorithm or a custom function",
