{
  "name": "@jssg/utils",
  "version": "0.0.6",
  "description": "Codemod utils for jssg engine",
  "homepage": "https://github.com/codemod/codemod",
  "repository": "https://github.com/codemod/codemod",
  "author": "Mohebifar <mo@codemod.com>",
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    "./javascript/*": {
      "types": "./src/javascript/exports/*.ts",
      "default": "./src/javascript/exports/*.ts"
    }
  },
  "scripts": {
    "build:test-cli": "cargo build -q --release --manifest-path ../../Cargo.toml -p codemod",
    "test": "pnpm build:test-cli && pnpm test:unit && pnpm test:semantic:raw",
    "test:unit": "../../target/release/codemod jssg exec ./tests/imports.test.ts && ../../target/release/codemod jssg exec ./tests/context.test.ts",
    "test:semantic": "pnpm build:test-cli && pnpm test:semantic:raw",
    "test:semantic:bindings": "pnpm build:test-cli && pnpm test:semantic:raw bindings",
    "test:semantic:raw": "node ./tests/run-semantic-tests.mjs",
    "check-types": "npx tsc --noEmit",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@codemod.com/jssg-types": "workspace:*",
    "@codemod.com/tsconfig": "workspace:*",
    "typescript": "catalog:"
  },
  "publishConfig": {
    "access": "public"
  }
}
